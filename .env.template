# ─────────────────────────────────────────────────────────────────────────────
# TypeBlaze — Environment Variables
# Copy this file to .env.local for local dev
# Add all variables to Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://typeblaze.com
# Local dev: NEXTAUTH_URL=http://localhost:3000

# ── Database (get from Neon/Supabase/Railway after setup) ─────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/typeblaze?sslmode=require

# ── Auth Secrets — GENERATE THESE, never share them ──────────────────────────
# Run this to generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_64_BYTE_HEX_HERE

# Run this to generate: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_32_BYTE_BASE64_HERE

# ── Redis — Upstash (free tier at upstash.com) ────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ── Security Logging — Axiom (free tier at axiom.co) ─────────────────────────
AXIOM_DATASET=typeblaze-security
AXIOM_TOKEN=YOUR_AXIOM_TOKEN

